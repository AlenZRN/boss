# ---- 环境变量配置模板 ----
# 复制此文件为 .env 并填入实际值

# 阿里云
ALIYUN_ACCESS_KEY=your_access_key_here
ALIYUN_SECRET=your_secret_here
ALIYUN_REGION=cn-hangzhou
ALIYUN_COLLECTOR_ENABLED=true

# 火山云
VOLCENGINE_ACCESS_KEY=your_access_key_here
VOLCENGINE_SECRET=your_secret_here
VOLCENGINE_ENABLED=false
VOLCENGINE_REGIONS=cn-beijing,cn-shanghai,cn-guangzhou

# 数据库
DB_PASSWORD=aimira123

# 企业微信机器人 Webhook
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
WECOM_ENABLED=true

# 定时任务（Cron 表达式）
SCHEDULER_COLLECT_CRON=0 0 * * * *
SCHEDULER_ALARM_CRON=0 0 * * * *
ALARM_COOLDOWN_SECONDS=86400
